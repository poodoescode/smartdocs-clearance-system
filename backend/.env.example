# ============================================
# Backend Environment Variables Template
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit the .env file to Git
#
# ============================================

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (safe for client-side)
SUPABASE_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (KEEP SECRET - server-side only)
# WARNING: This key has admin privileges. Never expose it!
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for the Express server
PORT=5000

# ============================================
# RECAPTCHA CONFIGURATION
# ============================================
# Get this from: https://www.google.com/recaptcha/admin
# This is the SECRET key (server-side only)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ============================================
# NOTES
# ============================================
# - Keep this file updated when adding new environment variables
# - Document what each variable is used for
# - Never commit actual credentials to version control
